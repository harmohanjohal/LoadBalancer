<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.javafxapplication1.PrimaryController"
           prefWidth="600" prefHeight="450" styleClass="page-bg">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <!-- Centered card -->
    <VBox alignment="CENTER" maxWidth="380" maxHeight="-Infinity" spacing="24" styleClass="card">
        <padding><Insets top="40" right="36" bottom="40" left="36"/></padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="4">
            <Label text="Welcome Back" styleClass="title"/>
            <Label text="Sign in to your account" styleClass="subtitle"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="6">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="userTextField" promptText="Enter your username" prefWidth="300"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passPasswordField" promptText="Enter your password" prefWidth="300"/>
        </VBox>

        <!-- Buttons -->
        <VBox spacing="10" alignment="CENTER">
            <Button fx:id="loginBtn" text="Sign In" prefWidth="300" styleClass="btn-primary"
                    onAction="#switchToSecondary"/>
            <Button fx:id="registerBtn" text="Create Account" prefWidth="300" styleClass="btn-outline"
                    onAction="#registerBtnHandler"/>
        </VBox>
    </VBox>
</StackPane>
